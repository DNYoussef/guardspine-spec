{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guardspine.dev/schemas/evidence-bundle/v0.3.0",
  "title": "GuardSpine Evidence Bundle",
  "description": "Canonical tamper-evident evidence bundle format with SBOM, in-toto attestation, and sanitization support.",
  "type": "object",
  "required": ["bundle_id", "version", "created_at", "items", "immutability_proof"],
  "properties": {
    "bundle_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this bundle (UUID v4)."
    },
    "version": {
      "type": "string",
      "const": "0.3.0",
      "description": "Schema version."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of bundle creation."
    },
    "policy_id": {
      "type": "string",
      "description": "Optional reference to the policy pack used for evaluation."
    },
    "artifact_id": {
      "type": "string",
      "description": "Optional ID of the artifact this bundle covers."
    },
    "risk_tier": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "description": "Risk classification tier."
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/EvidenceItem" }
    },
    "immutability_proof": {
      "$ref": "#/$defs/ImmutabilityProof"
    },
    "signatures": {
      "type": "array",
      "items": { "$ref": "#/$defs/Signature" },
      "description": "Cryptographic signatures over the bundle."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Arbitrary metadata (retention, scope, audit trail)."
    },
    "sanitization": {
      "$ref": "#/$defs/SanitizationSummary"
    },
    "sbom": {
      "$ref": "#/$defs/SBOMReference",
      "description": "Software Bill of Materials reference for EU CRA compliance."
    },
    "attestation": {
      "$ref": "#/$defs/InTotoAttestation",
      "description": "in-toto supply chain attestation envelope."
    }
  },
  "$defs": {
    "EvidenceItem": {
      "type": "object",
      "required": ["item_id", "content_type", "content", "content_hash", "sequence"],
      "properties": {
        "item_id": {
          "type": "string",
          "description": "Unique identifier for this item."
        },
        "content_type": {
          "type": "string",
          "description": "MIME-like type tag, e.g. guardspine/test-result, guardspine/diff, guardspine/approval."
        },
        "content": {
          "type": ["object", "array"],
          "description": "Structured content. Objects or arrays accepted."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of RFC 8785 canonical JSON of content."
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based sequence number matching index in items array."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ImmutabilityProof": {
      "type": "object",
      "required": ["hash_chain", "root_hash"],
      "properties": {
        "hash_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/HashChainLink" }
        },
        "root_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 of the concatenated chain_hash values."
        }
      }
    },
    "HashChainLink": {
      "type": "object",
      "required": ["sequence", "item_id", "content_type", "content_hash", "previous_hash", "chain_hash"],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "item_id": { "type": "string" },
        "content_type": { "type": "string" },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "previous_hash": {
          "type": "string",
          "description": "chain_hash of the previous link, or 'genesis' for the first."
        },
        "chain_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "Signature": {
      "type": "object",
      "required": ["signature_id", "algorithm", "signer_id", "signature_value", "signed_at"],
      "properties": {
        "signature_id": { "type": "string" },
        "algorithm": {
          "type": "string",
          "enum": ["ed25519", "rsa-sha256", "ecdsa-p256", "hmac-sha256", "sigstore-cosign"]
        },
        "signer_id": { "type": "string" },
        "signature_value": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "public_key_id": { "type": "string" },
        "transparency_log_entry": {
          "type": "string",
          "format": "uri",
          "description": "URL to Rekor transparency log entry (for Sigstore signatures)."
        }
      }
    },
    "SanitizationSummary": {
      "type": "object",
      "required": [
        "engine_name", "engine_version", "method", "token_format",
        "salt_fingerprint", "redaction_count", "redactions_by_type", "status"
      ],
      "properties": {
        "engine_name": { "type": "string" },
        "engine_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "method": {
          "type": "string",
          "enum": ["deterministic_hmac", "provider_native", "entropy+hmac"]
        },
        "token_format": {
          "type": "string",
          "pattern": "^\\[HIDDEN:<id>\\]$"
        },
        "salt_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{8,64}$"
        },
        "redaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "redactions_by_type": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "input_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "applied_to": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ai_prompt", "pr_comment", "evidence_bundle", "sarif",
              "council_prompt", "webhook_payload", "docsync_pack"
            ]
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": ["sanitized", "none", "partial", "error"]
        }
      },
      "additionalProperties": false
    },
    "SBOMReference": {
      "description": "Software Bill of Materials reference for EU Cyber Resilience Act compliance.",
      "type": "object",
      "required": ["format", "spec_version"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["CycloneDX", "SPDX"],
          "description": "SBOM standard format."
        },
        "spec_version": {
          "type": "string",
          "description": "Version of the SBOM standard (e.g. '1.5' for CycloneDX)."
        },
        "serial_number": {
          "type": "string",
          "description": "SBOM document serial number or SPDX document namespace."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of the SBOM document content."
        },
        "component_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of components in the SBOM."
        },
        "vulnerability_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Known vulnerabilities at time of bundle creation."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the SBOM was generated."
        },
        "tool": {
          "type": "string",
          "description": "Tool that generated the SBOM (e.g. 'syft', 'trivy')."
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "description": "URI to the full SBOM document if stored externally."
        }
      },
      "additionalProperties": false
    },
    "InTotoAttestation": {
      "description": "in-toto supply chain attestation envelope (CNCF graduated project).",
      "type": "object",
      "required": ["_type", "predicateType"],
      "properties": {
        "_type": {
          "type": "string",
          "const": "https://in-toto.io/Statement/v1",
          "description": "in-toto statement type URI."
        },
        "predicateType": {
          "type": "string",
          "description": "Predicate type URI (e.g. https://slsa.dev/provenance/v1, https://guardspine.dev/governance/v1)."
        },
        "subject": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "digest"],
            "properties": {
              "name": { "type": "string" },
              "digest": {
                "type": "object",
                "properties": {
                  "sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "required": ["sha256"]
              }
            }
          },
          "description": "Artifacts the attestation applies to."
        },
        "predicate": {
          "type": "object",
          "additionalProperties": true,
          "description": "Attestation predicate content (format depends on predicateType)."
        }
      },
      "additionalProperties": false
    }
  }
}
